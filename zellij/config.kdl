theme "tokyonight_moon"

keybinds { 
    tab {
        bind "Shift Left" "H" { MoveTab "Left"; }
        bind "Shift Right" "L" { MoveTab "Right"; }
    }
}

simplified_ui false
// More space. Can be toggled with Ctrl+p z
pane_frames false

web_client {
    font "monospace"
}

support_kitty_keyboard_protocol false

// Feature not used
session_serialization false
// Together with the above we also throw away sessions when closing the last terminal
on_force_close "quit"
